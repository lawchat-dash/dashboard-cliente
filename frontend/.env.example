# Conexão com o Postgres do Supabase (server.js)
# Copie para frontend/.env e preencha — OU defina como variáveis de ambiente no easypanel.
# NUNCA commite o .env real (senha do banco).

DB_HOST=db.xxxxxxxxxxxx.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASS=sua_senha_aqui
DB_NAME=postgres

# Porta do server (em produção o easypanel injeta PORT automaticamente)
# PORT=8787
